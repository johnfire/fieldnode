<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/browser_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/path_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:fontFamily="monospace"
        android:textSize="13sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <Button android:id="@+id/up_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/browser_up" />

            <Button android:id="@+id/new_file_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/browser_new_file" />

            <Button android:id="@+id/new_folder_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/browser_new_folder" />

            <Button android:id="@+id/trash_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/browser_trash" />

            <Button android:id="@+id/log_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/browser_log" />
        </LinearLayout>
    </HorizontalScrollView>

    <ListView
        android:id="@+id/entry_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
