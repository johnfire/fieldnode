<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      MANAGE_EXTERNAL_STORAGE is declared now (step 0.3 wires the runtime grant flow).
      Full-device file authority is the whole point; it is gated in-app by the
      trash-not-rm + confirm + earned-scope safety layer (step 0.5), never raw.
    -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- 0.7 survival canary: a foreground service + autostart-on-boot, to measure whether stock
         MIUI lets a background service live (the v1.5 notify-back risk probe). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- On-site awareness (v2b): foreground location to find leads near the phone. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Phone posts captures to the fleet over the network (HTTPS in prod). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Fieldnode">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".FileBrowserActivity"
            android:exported="false"
            android:label="@string/open_file_browser" />

        <activity
            android:name=".CapturesActivity"
            android:exported="false"
            android:label="@string/open_captures" />

        <activity
            android:name=".NearbyActivity"
            android:exported="false"
            android:label="@string/open_nearby" />

        <activity
            android:name=".AgentActivity"
            android:exported="false"
            android:label="@string/open_agent"
            android:windowSoftInputMode="adjustResize" />

        <!-- Share target: receive text / images from any app into the capture queue. -->
        <activity
            android:name=".ShareReceiverActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <service
            android:name=".SurvivalCanaryService"
            android:exported="false" />

        <service
            android:name=".NotifyService"
            android:exported="false" />

        <!-- Mints content:// URIs so files can be handed to the system share sheet (v2 share-out). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Flush the capture queue to the fleet on broadcast (automation / testing). -->
        <receiver
            android:name=".DispatchReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="de.christopherrehm.fieldnode.DISPATCH" />
                <action android:name="de.christopherrehm.fieldnode.NOTIFY_START" />
                <action android:name="de.christopherrehm.fieldnode.NOTIFY_STOP" />
            </intent-filter>
        </receiver>

        <!-- Runs notification action buttons (one-tap approve). Internal only. -->
        <receiver
            android:name=".ActionReceiver"
            android:exported="false" />
    </application>
</manifest>
