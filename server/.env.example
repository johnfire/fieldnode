# Copy to .env on the VPS and fill in. NEVER commit the real .env.
# Device token the phone presents (generate a strong random one; goes in the phone's fleet.config too):
FIELDNODE_DEVICE_TOKEN=replace-with-a-long-random-token
# Destination: Open Brain MCP endpoint + access key (your own Supabase project / brain key):
OPEN_BRAIN_MCP_URL=https://YOUR-PROJECT.supabase.co/functions/v1/open-brain-mcp
OPEN_BRAIN_KEY=replace-with-your-open-brain-access-key
# Project tag applied to captured thoughts in Open Brain:
FIELDNODE_PROJECT=fieldnode
